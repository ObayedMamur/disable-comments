# Copy to .env.openclaw and fill in your values.
# Never commit .env.openclaw — it's gitignored.
#
# First-time setup:
#   docker run --rm -v openclaw_openclaw-config:/config alpine sh -c \
#     'printf "%s" "{\"gateway\":{\"controlUi\":{\"dangerouslyAllowHostHeaderOriginFallback\":true}}}" \
#      > /config/openclaw.json && chown -R 1000:1000 /config'

# --- Gateway auth (required if binding beyond loopback) ---
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-long-random-token

# --- Model provider (set at least one) ---
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...

# --- WordPress dev site (via host.docker.internal) ---
# Available inside the container as http://host.docker.internal:8890 (dev)
# and http://host.docker.internal:8891 (tests) — no extra config needed.

# --- Optional ---
# OPENCLAW_GATEWAY_PORT=18789
# OPENCLAW_TZ=UTC
